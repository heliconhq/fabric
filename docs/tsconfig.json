{
  "compilerOptions": {
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "target": "es2015",
    "jsx": "react",
    "types": ["react", "node"],
    "module": "esNext",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "declaration": false,
    "removeComments": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "strict": true,
    "outDir": "dist",
    "baseUrl": "src",
    "typeRoots": ["./src/@types", "./types", "node_modules/@types"],
    "strictNullChecks": true,
    "allowJs": true,
    "lib": ["DOM", "ESNext"]
  },
  "exclude": ["dist", "node_modules", "example", "storybook", "docs", "scripts"]
}
