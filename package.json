{
  "name": "fabric-monorepo",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/*"
  ],
  "scripts": {
    "docs:install": "cd docs && npm install",
    "docs:start": "cd docs && npm run start",
    "postinstall": "npm run docs:install",
    "start": "npm run docs:start",
    "build": "npm run build --ws",
    "test": "npm run test --ws --if-present",
    "publish": "npm run publish --ws --if-present",
    "dev:all": "./scripts/run_docs.sh",
    "install:all": "./scripts/install_all.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/cli": "^7.17.10",
    "@babel/core": "^7.17.10",
    "@babel/eslint-parser": "^7.17.0",
    "@babel/preset-env": "^7.11.5",
    "@babel/preset-react": "^7.8.3",
    "@babel/preset-typescript": "^7.15.0",
    "@changesets/cli": "^2.22.0",
    "@emotion/babel-plugin": "^11.12.0",
    "@emotion/babel-preset-css-prop": "^11.12.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@types/apca-w3": "^0.1.3",
    "@types/chroma-js": "^2.4.4",
    "@types/jest": "^29.5.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "8.4.0",
    "@typescript-eslint/parser": "8.4.0",
    "babel-plugin-extract-react-types": "^0.1.14",
    "babel-plugin-react-defaultprops": "^1.0.9",
    "concurrently": "^7.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "7.35.2",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "typescript": "^5.6.3",
    "@emotion/jest": "^11.13.0"
  },
  "dependencies": {
    "date-fns": "4.1.0",
    "@emotion/is-prop-valid": "^1.2.0",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0 ."
    ]
  }
}
