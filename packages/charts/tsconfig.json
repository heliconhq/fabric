{
  "compilerOptions": {
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "target": "es2015",
    "jsx": "react-jsx",
    "types": [
      "react"
    ],
    "jsxImportSource": "@emotion/react",
    "module": "esNext",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "declaration": true,
    "removeComments": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "typeRoots": [
      "./src/types",
      "../../node_modules/@types",
      "node_modules/@types"
    ],
    "strictNullChecks": true,
    "allowJs": true
  },
  "exclude": [
    "dist",
    "node_modules"
  ]
}
