{
  "compilerOptions": {
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "target": "es2015",
    "jsx": "react-jsx",
    "types": ["react", "@testing-library/jest-dom"],
    "jsxImportSource": "@emotion/react",
    "module": "esNext",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "declaration": true,
    "removeComments": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["dom", "ESNext"],
    "typeRoots": [
      "./src/types",
      "node_modules/@types",
      "../../node_modules/@types"
    ],
    "strictNullChecks": true,
    "allowJs": true
  },
  "exclude": ["scripts", "node_modules", "dist"]
}
